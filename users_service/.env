# Spring Boot Backend Environment Variables

# Database Configuration
SPRING_MONGODB_URI=mongodb://localhost:27017/eras_db

# User Configuration
USER_CAN_DELETE_OWN_ACCOUNT=false
USER_USERNAME_MIN_LENGTH=3
USER_USERNAME_MAX_LENGTH=20
USER_PASSWORD_MIN_LENGTH=8
USER_PASSWORD_MAX_LENGTH=64
USER_PASSWORD_HAS_UPPERCASE=true
USER_PASSWORD_HAS_LOWERCASE=true
USER_PASSWORD_HAS_DIGIT=true
USER_PASSWORD_HAS_SPECIAL=true
USER_PASSWORD_SPECIAL_CHARS=!@#$%^&*()_+-=[]{}|;':\",./<>?

# JWT Configuration
JWT_SECRET=your-very-long-base64-encoded-secret-key-here-change-this-in-production
JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ALLOWED_ORIGIN=http://localhost:5175

# Roles Configuration
ROLES_BASE_USERNAME=admin
ROLES_BASE_PASSWORD=.Waren123
ROLES_ALLOWED=true
ROLES_BASE_ROLE=DEVELOPER

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=erasmailbox@gmail.com
